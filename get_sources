#!/usr/bin/env bash
set -euo pipefail

# Apply coot CMakeLists patch if not already applied (idempotent).
if ! git -C coot apply --check --reverse ../patches/coot-cmakelists.patch 2>/dev/null; then
    git -C coot apply ../patches/coot-cmakelists.patch
    echo "Applied coot-cmakelists.patch"
else
    echo "coot-cmakelists.patch already applied"
fi

mkdir -p checkout
cd checkout

if [ -d "clipper" ]; then
    echo "Found clipper"
else
    # echo "Checking out clipper"
    git clone https://ccp4forge.rc-harwell.ac.uk/ccp4/clipper.git clipper-gemmi
    cd clipper-gemmi
    git checkout gemmi
    find . -maxdepth 1 ! -name 'clipper' ! -name '.' ! -name '.git' -exec rm -rf {} +
    git apply ../../patches/clipper-*.patch
    cd ..
    mv clipper-gemmi clipper
    # echo
    #  echo "Checking out clipper"
    # git clone https://ccp4forge.rc-harwell.ac.uk/ccp4/clipper.git clipper
    # cd clipper
    # git checkout large_maps_support
    # git apply ../../patches/clipper-*.patch
    # cd ..
    # mv clipper-gemmi clipper
    echo
    
fi

if [ -d "gemmi" ]; then
    echo "Found gemmi"
else
    echo "Checking out gemmi"
    git clone https://github.com/project-gemmi/gemmi.git gemmi
    cd gemmi
    git checkout v0.7.3
    rm CMakeLists.txt
    cd ..
    echo
fi

if [ -d "mmdb2" ]; then
    echo "Found mmdb2"
else
    echo "Checking out mmdb2"
    curl -L http://www.ysbl.york.ac.uk/jsd523/mmdb2-2.0.22.tar.gz -o mmdb2-2.0.22.tar.gz
    tar xf mmdb2-2.0.22.tar.gz
    ln -s mmdb2-2.0.22 mmdb2
    echo
fi

if [ -d "libccp4" ]; then
    echo "Found libccp4"
else
    echo "Checking out libccp4"
    curl -L http://www.ysbl.york.ac.uk/jsd523/libccp4-8.0.0.tar.gz -o libccp4-8.0.0.tar.gz
    tar xf libccp4-8.0.0.tar.gz
    mv libccp4-8.0.0 libccp4
    echo
fi

if [ -d "fftw-2.1.5" ]; then
    echo "Found fftw-2.1.5"
else

    echo "Downloading out fftw-2.1.5"
    curl -L http://www.fftw.org/fftw-2.1.5.tar.gz -o fftw-2.1.5.tar.gz
    echo
    echo "Unpacking fftw-2.1.5"
    tar xf fftw-2.1.5.tar.gz
    echo
fi

if [ -d "ssm" ]; then
    echo "Found ssm"
else
    echo "Checking out ssm"
    git clone https://ccp4forge.rc-harwell.ac.uk/ccp4/ssm.git ssm
    echo
fi

glm_release="1.0.1"
if [ -d "glm" ]; then
    echo "Found glm"
else
    echo "Downloading glm-$glm_release"
    curl -L https://github.com/g-truc/glm/archive/refs/tags/$glm_release.tar.gz -o glm-$glm_release.tar.gz
    tar xf glm-$glm_release.tar.gz
    mv glm-$glm_release glm
    echo
fi

fftw3_release="3.3.10"
if [ -r fftw3 ]; then
    echo "Using existing fftw3"
else
    echo "Downloading out fftw-$fftw3_release"
    curl -L http://www.fftw.org/fftw-$fftw3_release.tar.gz -o fftw-$fftw3_release.tar.gz
    echo
    echo "Unpacking fftw-$fftw3_release"
    tar xf fftw-$fftw3_release.tar.gz
    mv fftw-$fftw3_release fftw3
fi

rdkit_release="Release_2024_09_5"
if [[ "$(uname)" == "Linux" ]]; then
    if [ -f "/opt/rdkit/lib/libRDKitRDGeneral.so" ]; then
        echo "Found RDKit"
    else
        echo "Building RDKit ${rdkit_release} from source"
        if [ ! -d "rdkit-${rdkit_release}" ]; then
            curl -L "https://github.com/rdkit/rdkit/archive/refs/tags/${rdkit_release}.tar.gz" -o rdkit.tar.gz
            tar xf rdkit.tar.gz
            rm rdkit.tar.gz
        fi
        cmake -S "rdkit-${rdkit_release}" -B rdkit-build \
            -GNinja \
            -DCMAKE_BUILD_TYPE=Release \
            -DCMAKE_INSTALL_PREFIX=/opt/rdkit \
            -DRDK_BUILD_PYTHON_WRAPPERS=OFF \
            -DRDK_BUILD_CPP_TESTS=OFF \
            -DRDK_BUILD_CAIRO_SUPPORT=ON \
            -DRDK_INSTALL_INTREE=OFF \
            -DRDK_BUILD_INCHI_SUPPORT=ON \
            -DRDK_BUILD_AVALON_SUPPORT=ON \
            -DRDK_BUILD_FREETYPE_SUPPORT=OFF
        cmake --build rdkit-build -j$(nproc)
        cmake --install rdkit-build
        rm -rf rdkit-build
        echo "RDKit installed to /opt/rdkit"
    fi
fi

# RDKit's Homebrew cmake config references /opt/homebrew/lib/libexpat.a, but expat is keg-only
# so that path doesn't exist. Create a symlink at the expected location.
if [[ "$(uname)" == "Darwin" ]]; then
    EXPAT_A="$(brew --prefix)/lib/libexpat.a"
    EXPAT_KEG_A="$(brew --prefix expat)/lib/libexpat.a"
    if [ ! -f "$EXPAT_A" ] && [ -f "$EXPAT_KEG_A" ]; then
        ln -sf "$EXPAT_KEG_A" "$EXPAT_A"
        echo "Symlinked libexpat.a: $EXPAT_A -> $EXPAT_KEG_A"
    fi
fi

# Force the cmake_minimum_required bump regardless of patch state.
# (Works on both GNU sed and BSD/macOS sed via -i'' backup-empty form.)
if [ -f fftw3/CMakeLists.txt ]; then
    sed -i.bak -E 's/^cmake_minimum_required *\( *VERSION *[0-9.]+ *\)/cmake_minimum_required(VERSION 3.13)/' fftw3/CMakeLists.txt
    rm -f fftw3/CMakeLists.txt.bak
    head -1 fftw3/CMakeLists.txt
fi
echo


cd ..
